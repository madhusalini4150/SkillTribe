# Copy this file to ".env" and fill in your own values.
# NEVER commit the real .env file to GitHub — it's already in .gitignore.

# A long random string — generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Leave blank locally to use SQLite automatically.
# On Render/Railway, this is provided automatically when you add a Postgres database.
DATABASE_URL=

# development OR production
FLASK_ENV=development

# Set to "true" only the very first time you want sample teachers/users created
SEED_DEMO=true
